{
  "name": "angular-coverage-badges-action",
  "version": "3.0.0",
  "private": true,
  "description": "GitHub action that generates coverage badges for Angular projects without external providers and updates a GitHub repository automatically",
  "main": "lib/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "pack": "esbuild lib/main.js --bundle --platform=node --target=node24 --format=esm --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --outfile=dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run build && npm run format && npm run lint && npm run pack && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demyanets/angular-coverage-badges-action.git"
  },
  "keywords": [
    "github",
    "action",
    "node",
    "angular",
    "karma",
    "istanbul",
    "coverage",
    "badge",
    "generate",
    "standalone"
  ],
  "author": "Taras Demyanets",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/io": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.25.1",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
