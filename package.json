{
  "name": "angular-coverage-badges-action",
  "version": "1.1.0",
  "private": true,
  "description": "GitHub action that generates coverage badges for Angular projects without external providers and updates a GitHub repository automatically",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "pack": "ncc build",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run pack && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demyanets/angular-coverage-badges-action.git"
  },
  "keywords": [
    "github",
    "action",
    "node",
    "angular",
    "karma",
    "istanbul",
    "coverage",
    "badge",
    "generate",
    "standalone"
  ],
  "author": "Taras Demyanets",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/github": "^8.0.1",
    "@actions/io": "^1.1.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.0.0",
    "eslint-plugin-jest": "^28.11.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.32.0",
    "jest": "^30.0.0",
    "jest-circus": "^30.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "test-exclude": "^8.0.0",
    "glob": "^12.0.0"
  }
}
